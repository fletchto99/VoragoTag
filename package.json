{
  "name": "voragotag",
  "version": "1.0.0",
  "description": "An Alt1 overlay that times the target-cycle ult for the Vorago GM rotation.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "watch": "webpack --watch --mode development",
    "test": "tsx --test test/*.test.ts",
    "lint": "npm run lint:ts && npm run lint:css && npm run format:check",
    "lint:ts": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "alt1": "^0.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "style-loader": "^4.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-loader": "^9.6.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
